# LM Studio configuration
# Required unless you pass --model on the CLI.
# Use the exact model identifier shown by LM Studio.
LMSTUDIO_MODEL="your-downloaded-lm-studio-model"
# Optional: live integration tests prefer this small loaded text model over LMSTUDIO_MODEL.
# Current known-small local option: qwen_qwen3.5-0.8b
LMSTUDIO_TEST_MODEL="qwen_qwen3.5-0.8b"
LMSTUDIO_BASE_URL="http://localhost:1234/v1"
LMSTUDIO_API_KEY="lm-studio"

# HyperGraph topic generation can use OpenAI or any OpenAI-compatible endpoint.
# By default it reuses LMSTUDIO_* when LMSTUDIO_BASE_URL is set.
# Override these when the UI should use a different provider/model than the CLI.
# HYPERGRAPH_OPENAI_BASE_URL="http://localhost:1234/v1"
# HYPERGRAPH_OPENAI_API_KEY="lm-studio"
# HYPERGRAPH_OPENAI_MODEL="qwen_qwen3.5-0.8b"
# HYPERGRAPH_OPENAI_RESPONSE_FORMAT="json_schema" # json_schema | json_object | text

# GitHub API configuration
# Optional for public repositories, but recommended for rate limits and required for private repositories.
# Do not commit real tokens.
GITHUB_ACCESS_TOKEN=""
# GH_TOKEN=""

# Artifact output
OUTPUT_DIR="artifacts"

# Optional generation features
ENABLE_CTX="0"
ENABLE_REPO_GRAPH="0"
ENABLE_SESSION_MEMORY="0"
LMSTUDIO_STREAMING="1"
LMSTUDIO_AUTO_UNLOAD="1"

# Context budget controls
MAX_CONTEXT_TOKENS="32768"
MAX_OUTPUT_TOKENS="4096"
CONTEXT_HEADROOM_RATIO="0.15"
MAX_FILE_TREE_LINES="1200"
MAX_README_CHARS="24000"
MAX_PACKAGE_CHARS="18000"
RETRY_REDUCTION_STEPS="0.70,0.50"
