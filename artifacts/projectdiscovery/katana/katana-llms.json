          "type": "string"
        }
      },
      "sections": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": [
            "title",
            "links"
          ],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "links": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "title",
                  "url",
                  "note"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "note": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
