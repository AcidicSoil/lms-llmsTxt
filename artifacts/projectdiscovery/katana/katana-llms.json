{
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "llmsTxtDocument",
    "type": "object",
    "required": [
      "project",
      "remember",
      "sections"
    ],
    "properties": {
      "project": {
        "type": "object",
        "required": [
          "name",
          "summary"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "remember": {
        "type": "array",
