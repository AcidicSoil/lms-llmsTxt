{
  "name": "codefetch-runner",
  "private": true,
  "scripts": {
    "ui:dev": "npm --prefix hypergraph run dev",
    "ui:build": "npm --prefix hypergraph run build",
    "ui:start": "npm --prefix hypergraph run start",
    "code:s": "codefetch -t 5 --include-dir src --exclude-dirs __pycache__ --exclude-files *.pyc -o src.md",
    "code:d": "codefetch --include-dir docs --exclude-dirs __pycache__ -o docs_codebase.md",
    "code:art": "node scripts/codefetch-artifacts.mjs",
    "code:b": "bash scripts/codefetch-artifacts.sh",
    "code": "pnpm code:s && pnpm code:d && pnpm code:t",
    "code:t": "codefetch -t 5 --include-files \"hypergraph/*app*/**/*\",\"hypergraph/*components*/**/*\",\"hypergraph/*types*/**/*\",\"hypergraph/*app*/**/*\" -o hg.md",
    "scri": "bash scripts/codefetch/codefetch_skill.sh ",
    "scrip": "bash scripts/codefetch/codefetch_skills_pattern.sh"
  },
  "devDependencies": {
    "codefetch": "^2.2.0"
  },
  "packageManager": "pnpm@10.29.2+sha512.bef43fa759d91fd2da4b319a5a0d13ef7a45bb985a3d7342058470f9d2051a3ba8674e629672654686ef9443ad13a82da2beb9eeb3e0221c87b8154fff9d74b8"
}
